rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can only read/write their own answer docs.
    // Path: users/{uid}/answers/{dateId}
    match /users/{userId}/answers/{dateId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
